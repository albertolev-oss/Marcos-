# URL base del PACS VisualMedica. Ej: https://pacs.visualmedica.example
PACS_BASE_URL=
PACS_USER=TU_USUARIO
PACS_PASS=TU_CONTRASEÑA

# Cambiar a true para correr sin ventana en servidor.
HEADLESS=false

# Token largo y secreto de al menos 32 caracteres para la API REST / ChatGPT Actions.
HTTP_API_TOKEN=un_token_largo_y_secreto_de_32_caracteres

# Opcionales: selectores si el PACS cambia su interfaz.
PACS_USER_SELECTOR=input[name="username"], input[type="text"]
PACS_PASS_SELECTOR=input[name="password"], input[type="password"]
PACS_LOGIN_BUTTON_SELECTOR=button[type="submit"], input[type="submit"]
PACS_SEARCH_SELECTOR=input[type="search"], input[name="search"], input[placeholder*="Buscar"], input[placeholder*="Paciente"]
PACS_VIEWER_SELECTOR=body
